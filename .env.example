# ─── Database ─────────────────────────────────────────────────────
DATABASE_URL="postgresql://perfpatrol:perfpatrol@localhost:5432/perfpatrol?schema=public"

# Override for Docker Compose (uses service names):
# DATABASE_URL="postgresql://perfpatrol:perfpatrol@postgres:5432/perfpatrol?schema=public"

# PostgreSQL credentials (used by docker-compose)
POSTGRES_USER="perfpatrol"
POSTGRES_PASSWORD="perfpatrol"
POSTGRES_DB="perfpatrol"

# ─── Redis ────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Web App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Worker ───────────────────────────────────────────────────────
WORKER_CONCURRENCY=2
RATE_LIMIT_MAX=5
RATE_LIMIT_DURATION=60000
